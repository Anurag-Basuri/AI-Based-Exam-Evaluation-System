# ── LLM Providers (fill at least one) ──
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
HF_API_KEY=

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./chroma_data

# ── Server ──
AGENT_SERVICE_PORT=8001
AGENT_SERVICE_HOST=0.0.0.0

# ── Node.js Backend URL (for callbacks if needed) ──
NODE_BACKEND_URL=http://localhost:5000

# ── Embedding Model ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LLM defaults ──
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
